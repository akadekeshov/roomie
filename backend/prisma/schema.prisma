generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        String                    @id @default(uuid())
  email                     String?                   @unique
  phone                     String?                   @unique
  password                  String
  role                      UserRole                  @default(USER)
  isBanned                  Boolean                   @default(false)
  warningCount              Int                       @default(0)
  isRestricted              Boolean                   @default(false)
  restrictedUntil           DateTime?
  bannedAt                  DateTime?
  banReason                 String?
  profileTrustPenalty       Int                       @default(0)
  emailVerified             Boolean                   @default(false)
  phoneVerified             Boolean                   @default(false)
  firstName                 String?
  lastName                  String?
  gender                    Gender?
  age                       Int?
  city                      String?
  bio                       String?
  onboardingCompleted       Boolean                   @default(false)
  onboardingStep            OnboardingStep            @default(NAME_AGE)
  occupationStatus          OccupationStatus?
  university                String?
  chronotype                Chronotype?
  noisePreference           NoisePreference?
  personalityType           PersonalityType?
  smokingPreference         SmokingPreference?
  petsPreference            PetsPreference?
  searchBudgetMin           Int?
  searchBudgetMax           Int?
  searchDistrict            String?
  roommateGenderPreference  RoommateGenderPreference?
  stayTerm                  String?
  photos                    String[]
  verificationStatus        VerificationStatus        @default(NONE)
  verificationDocumentUrl   String?
  verificationSelfieUrl     String?
  verificationRejectReason  String?
  verificationReviewedAt    DateTime?
  verificationReviewedBy    String?
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
  matchingPriorities        Json                      @default("{\"budget\": \"important\", \"district\": \"important\", \"chronotype\": \"neutral\", \"petsPreference\": \"important\", \"noisePreference\": \"neutral\", \"personalityType\": \"neutral\", \"occupationStatus\": \"neutral\", \"smokingPreference\": \"important\"}")
  conversationParticipants  ConversationParticipant[]
  favoriteUsers             FavoriteUser[]            @relation("FavoriteOwner")
  favoritedBy               FavoriteUser[]            @relation("FavoriteTarget")
  listings                  Listing[]
  sentMessages              Message[]
  refreshTokens             RefreshToken[]
  savedListings             SavedListing[]
  embedding                 UserEmbedding?
  aiRecommendationsGiven    AiRecommendationCache[]   @relation("AiRecommendationCurrentUser")
  aiRecommendationsReceived AiRecommendationCache[]   @relation("AiRecommendationCandidateUser")
  aiUnifiedProfile          AiUnifiedProfile?
  aiEmbeddings              AiEmbedding[]
  aiSearchSessions          AiSearchSession[]
  aiSearchResults           AiSearchResult[]          @relation("AiSearchResultTargetUser")
  createdAgreements         RoommateAgreement[]       @relation("AgreementCreator")
  firstUserAgreements       RoommateAgreement[]       @relation("AgreementFirstUser")
  secondUserAgreements      RoommateAgreement[]       @relation("AgreementSecondUser")
  paymentCards              UserPaymentCard[]
  agreementPayments         AgreementPayment[]        @relation("AgreementPaymentPayer")
  reportedDisputes          Dispute[]                 @relation("DisputeReporter")
  accusedDisputes           Dispute[]                 @relation("DisputeAccused")
  reviewedDisputes          Dispute[]                 @relation("DisputeReviewedBy")

  @@map("users")
}

model UserEmbedding {
  id              String   @id @default(uuid())
  userId          String   @unique
  profileText     String
  profileTextHash String
  model           String
  dimensions      Int
  vector          Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_embeddings")
}

model AiRecommendationCache {
  id              String   @id @default(uuid())
  currentUserId   String
  candidateUserId String
  ruleScore       Float
  embeddingScore  Float?
  aiScore         Float?
  finalScore      Float
  reasoning       String?
  strengths       Json?
  risks           Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  currentUser   User @relation("AiRecommendationCurrentUser", fields: [currentUserId], references: [id], onDelete: Cascade)
  candidateUser User @relation("AiRecommendationCandidateUser", fields: [candidateUserId], references: [id], onDelete: Cascade)

  @@unique([currentUserId, candidateUserId])
  @@index([currentUserId])
  @@index([candidateUserId])
  @@map("ai_recommendation_cache")
}

model AiUnifiedProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  profileText   String
  profileJson   Json
  profileHash   String
  completeness  Float
  sourceVersion Int
  builtAt       DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  embeddings AiEmbedding[]

  @@index([profileHash])
  @@map("ai_unified_profiles")
}

model AiEmbedding {
  id          String          @id @default(uuid())
  kind        AiEmbeddingKind
  userId      String?
  aiProfileId String?
  queryText   String
  queryHash   String
  model       String
  dimensions  Int
  vector      Json
  generatedAt DateTime        @default(now())

  user      User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiProfile AiUnifiedProfile? @relation(fields: [aiProfileId], references: [id], onDelete: SetNull)
  sessions  AiSearchSession[] @relation("AiSearchQueryEmbedding")

  @@index([kind, userId, generatedAt])
  @@index([aiProfileId])
  @@index([queryHash])
  @@map("ai_embeddings")
}

model AiSearchSession {
  id               String         @id @default(uuid())
  userId           String
  query            String
  normalizedQuery  String?
  parsedFilters    Json?
  queryEmbeddingId String?
  status           AiSearchStatus
  errorMessage     String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  queryEmbedding AiEmbedding?     @relation("AiSearchQueryEmbedding", fields: [queryEmbeddingId], references: [id], onDelete: SetNull)
  results        AiSearchResult[]

  @@index([userId, createdAt])
  @@index([queryEmbeddingId])
  @@map("ai_search_sessions")
}

model AiSearchResult {
  id                 String   @id @default(uuid())
  sessionId          String
  targetUserId       String
  semanticSimilarity Float
  lifestyleMatch     Float
  preferenceMatch    Float
  behavioralMatch    Float
  profileQuality     Float
  finalScore         Float
  matchedFields      String[]
  explanation        Json?
  createdAt          DateTime @default(now())

  session    AiSearchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  targetUser User            @relation("AiSearchResultTargetUser", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@unique([sessionId, targetUserId])
  @@index([targetUserId])
  @@index([sessionId, finalScore])
  @@map("ai_search_results")
}

model OtpCode {
  id         String     @id @default(uuid())
  channel    OTPChannel
  purpose    OTPPurpose
  target     String
  codeHash   String
  expiresAt  DateTime
  attempts   Int        @default(0)
  lastSentAt DateTime
  consumedAt DateTime?
  createdAt  DateTime   @default(now())

  @@unique([channel, purpose, target])
  @@index([channel, purpose, target])
  @@map("otp_codes")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Listing {
  id            String         @id @default(uuid())
  title         String
  description   String
  address       String
  city          String
  state         String?
  zipCode       String?
  country       String
  price         Float
  roomType      RoomType
  availableFrom DateTime?
  availableTo   DateTime?
  amenities     String[]
  images        String[]
  ownerId       String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  owner         User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  savedBy       SavedListing[]

  @@map("listings")
}

model SavedListing {
  id        String   @id @default(uuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@map("saved_listings")
}

model FavoriteUser {
  id           String   @id @default(uuid())
  ownerId      String
  targetUserId String
  createdAt    DateTime @default(now())
  owner        User     @relation("FavoriteOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  target       User     @relation("FavoriteTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@unique([ownerId, targetUserId])
  @@map("favorite_users")
}

model Conversation {
  id           String                    @id @default(uuid())
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  participants ConversationParticipant[]
  messages     Message[]
  agreements   RoommateAgreement[]
  disputes     Dispute[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String       @id @default(uuid())
  conversationId String
  userId         String
  createdAt      DateTime     @default(now())
  lastReadAt     DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_participants")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  text           String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

model RoommateAgreement {
  id                       String             @id @default(uuid())
  conversationId           String?
  creatorId                String
  firstUserId              String
  secondUserId             String
  status                   AgreementStatus    @default(DRAFT)
  city                     String?
  address                  String?
  moveInDate               DateTime?
  moveOutDate              DateTime?
  monthlyRent              Int?
  depositAmount            Int?
  housingFound             Boolean            @default(false)
  utilitySplitType         String?
  firstUserUtilityPercent  Int?
  secondUserUtilityPercent Int?
  houseRules               String?
  guestPolicy              String?
  quietHours               String?
  cleaningSchedule         String?
  smokingPolicy            String?
  petPolicy                String?
  noticePeriodDays         Int?               @default(30)
  damageResponsibility     String?
  terminationTerms         String?
  disputeTerms             String?
  sentForConfirmationAt    DateTime?
  firstUserConfirmedAt     DateTime?
  secondUserConfirmedAt    DateTime?
  cancelledAt              DateTime?
  cancelledById            String?
  rejectedAt               DateTime?
  rejectedById             String?
  completedAt              DateTime?
  pdfUrl                   String?
  digitalSignatureStatus   String?
  notaryStatus             String?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  conversation             Conversation?      @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  creator                  User               @relation("AgreementCreator", fields: [creatorId], references: [id])
  firstUser                User               @relation("AgreementFirstUser", fields: [firstUserId], references: [id])
  secondUser               User               @relation("AgreementSecondUser", fields: [secondUserId], references: [id])
  payments                 AgreementPayment[]
  disputes                 Dispute[]

  @@index([conversationId])
  @@index([firstUserId])
  @@index([secondUserId])
  @@index([status])
  @@map("roommate_agreements")
}

model UserPaymentCard {
  id        String            @id @default(uuid())
  userId    String
  provider  String?
  maskedPan String
  cardBrand String?
  status    CardBindingStatus @default(ACTIVE)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_payment_cards")
}

model AgreementPayment {
  id            String            @id @default(uuid())
  agreementId   String
  payerId       String
  type          PaymentType
  status        PaymentStatus     @default(PENDING)
  amount        Int
  currency      String            @default("KZT")
  dueDate       DateTime?
  paidAt        DateTime?
  description   String?
  mockReceiptNo String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  agreement     RoommateAgreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  payer         User              @relation("AgreementPaymentPayer", fields: [payerId], references: [id], onDelete: Cascade)

  @@index([agreementId])
  @@index([payerId])
  @@index([status])
  @@index([type])
  @@map("agreement_payments")
}

model Dispute {
  id                 String             @id @default(uuid())
  agreementId        String?
  conversationId     String?
  reporterId         String
  accusedId          String?
  reason             DisputeReason
  status             DisputeStatus      @default(OPEN)
  decision           DisputeDecision    @default(NONE)
  action             DisputeAction      @default(NONE)
  title              String
  description        String
  evidenceUrls       String[]           @default([])
  adminComment       String?
  resultText         String?
  reviewedById       String?
  reviewedAt         DateTime?
  actionAppliedAt    DateTime?
  actionExpiresAt    DateTime?
  accusedNotifiedAt  DateTime?
  reporterNotifiedAt DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  agreement          RoommateAgreement? @relation(fields: [agreementId], references: [id], onDelete: SetNull)
  conversation       Conversation?      @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  reporter           User               @relation("DisputeReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  accused            User?              @relation("DisputeAccused", fields: [accusedId], references: [id], onDelete: SetNull)
  reviewedBy         User?              @relation("DisputeReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([agreementId])
  @@index([conversationId])
  @@index([reporterId])
  @@index([accusedId])
  @@index([status])
  @@map("disputes")
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum AiEmbeddingKind {
  USER_PROFILE
  USER_PREFERENCES
  SEARCH_QUERY
}

enum AiSearchStatus {
  COMPLETED
  FAILED
}

enum RoomType {
  SINGLE
  DOUBLE
  SHARED
  ENTIRE_PLACE
}

enum OTPChannel {
  EMAIL
  PHONE
}

enum OTPPurpose {
  REGISTER
}

enum OnboardingStep {
  NAME_AGE
  GENDER
  CITY
  ABOUT
  LIFESTYLE
  SEARCH
  FINALIZE
  DONE
}

enum OccupationStatus {
  STUDY
  WORK
  STUDY_WORK
}

enum Chronotype {
  OWL
  LARK
}

enum NoisePreference {
  QUIET
  SOCIAL
}

enum PersonalityType {
  INTROVERT
  EXTROVERT
}

enum SmokingPreference {
  SMOKER
  NON_SMOKER
}

enum PetsPreference {
  WITH_PETS
  NO_PETS
}

enum RoommateGenderPreference {
  MALE
  FEMALE
  ANY
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum VerificationStatus {
  NONE
  PENDING
  VERIFIED
  REJECTED
}

enum AgreementStatus {
  DRAFT
  WAITING_SECOND_PARTY
  PENDING_CONFIRMATION
  ACTIVE
  CANCELLED
  COMPLETED
  REJECTED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentType {
  DEPOSIT
  MONTHLY_RENT
  UTILITIES
  OTHER
}

enum CardBindingStatus {
  ACTIVE
  REMOVED
  EXPIRED
}

enum DisputeStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  REJECTED
  CLOSED
}

enum DisputeDecision {
  NONE
  ACCEPTED
  REJECTED
  NEED_MORE_INFO
}

enum DisputeAction {
  NONE
  WARNING
  TEMPORARY_RESTRICTION
  ACCOUNT_BAN
  AGREEMENT_CANCELLED
  PAYMENT_REQUIRED
  PROFILE_FLAGGED
}

enum DisputeReason {
  PAYMENT_NOT_PAID
  AGREEMENT_VIOLATION
  PROPERTY_DAMAGE
  FAKE_INFORMATION
  RUDE_BEHAVIOR
  SAFETY_CONCERN
  OTHER
}
